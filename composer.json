{
    "name": "raprmdn/laravel-inertia-datatables",
    "description": "Laravel server-side data table query builder with optional Inertia React components.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Raprmdn\\DataTables\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Raprmdn\\DataTables\\DataTableServiceProvider"
            ],
            "aliases": {
                "DataTable": "Raprmdn\\DataTables\\Facades\\DataTable"
            }
        }
    },
    "authors": [
        {
            "name": "raprmdn",
            "email": "hello@raprmdn.dev"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/pagination": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "nesbot/carbon": "^2.72|^3.0"
    }
}
